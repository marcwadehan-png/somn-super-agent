# Somn 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ============================================================
# Somn AI 配置
# ============================================================
SOMN_ENV=development
SOMN_LOG_LEVEL=INFO
SOMN_HOST=0.0.0.0
SOMN_PORT=8964

# ============================================================
# LLM API 密钥 (至少需要配置一个)
# ============================================================
# MiniMax API
# SOMN_MINIMAX_API_KEY=your_minimax_api_key_here

# OpenAI API
# SOMN_OPENAI_API_KEY=your_openai_api_key_here

# DeepSeek API
# SOMN_DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ============================================================
# 可选: 本地模型配置
# ============================================================
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=gemma3:12b
