/*
 * Somn GUI - Light Theme
 * Fusion 风格亮色主题
 */

/* ── 全局 ── */
QMainWindow {
    background-color: #f5f6fa;
}
QWidget {
    font-family: "Microsoft YaHei", "Segoe UI", Arial, sans-serif;
    font-size: 13px;
    color: #2c3e50;
}

/* ── 菜单栏 ── */
QMenuBar {
    background-color: #ffffff;
    border-bottom: 1px solid #dee2e6;
    padding: 2px;
}
QMenuBar::item {
    padding: 6px 12px;
    background: transparent;
}
QMenuBar::item:selected {
    background-color: #e9ecef;
    border-radius: 4px;
}
QMenu {
    background-color: #ffffff;
    border: 1px solid #dee2e6;
    border-radius: 8px;
    padding: 6px;
}
QMenu::item {
    padding: 6px 24px;
    border-radius: 4px;
}
QMenu::item:selected {
    background-color: #007bff;
    color: white;
}
QMenu::separator {
    height: 1px;
    background: #dee2e6;
    margin: 4px 8px;
}

/* ── 标签页 ── */
QTabWidget::pane {
    border: 1px solid #dee2e6;
    border-radius: 8px;
    background-color: #ffffff;
    padding: 8px;
}
QTabBar::tab {
    background-color: #e9ecef;
    color: #495057;
    padding: 8px 20px;
    margin-right: 2px;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    font-weight: bold;
}
QTabBar::tab:selected {
    background-color: #ffffff;
    color: #007bff;
    border-bottom: 2px solid #007bff;
}

/* ── 按钮通用 ── */
QPushButton {
    background-color: #e9ecef;
    border: 1px solid #ced4da;
    border-radius: 6px;
    padding: 6px 16px;
    color: #495057;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #dee2e6;
    border-color: #adb5bd;
}
QPushButton:pressed {
    background-color: #ced4da;
}
QPushButton:disabled {
    background-color: #f8f9fa;
    color: #adb5bd;
}

/* ── 输入框 ── */
QLineEdit, QTextEdit {
    background-color: #ffffff;
    border: 1px solid #dee2e6;
    border-radius: 6px;
    padding: 8px;
    selection-background-color: #007bff;
    selection-color: white;
}
QLineEdit:focus, QTextEdit:focus {
    border-color: #007bff;
}

/* ── 文本浏览（聊天显示区） ── */
QTextBrowser {
    background-color: #f8f9fa;
    border: 1px solid #dee2e6;
    border-radius: 8px;
    padding: 12px;
    font-size: 13px;
}

/* ── 列表 ── */
QListWidget, QTreeWidget {
    background-color: #ffffff;
    border: 1px solid #dee2e6;
    border-radius: 6px;
    padding: 4px;
    alternate-background-color: #f8f9fa;
}
QListWidget::item, QTreeWidget::item {
    padding: 4px 8px;
    border-radius: 4px;
}
QListWidget::item:hover, QTreeWidget::item:hover {
    background-color: #e9ecef;
}
QListWidget::item:selected, QTreeWidget::item:selected {
    background-color: #007bff;
    color: white;
}

/* ── 状态栏 ── */
QStatusBar {
    background-color: #ffffff;
    border-top: 1px solid #dee2e6;
    color: #6c757d;
    font-size: 12px;
    padding: 2px 8px;
}
QProgressBar {
    border: 1px solid #dee2e6;
    border-radius: 4px;
    text-align: center;
    background-color: #e9ecef;
    height: 16px;
}
QProgressBar::chunk {
    background-color: #007bff;
    border-radius: 3px;
}

/* ── 分隔器 ── */
QSplitter::handle {
    background-color: #dee2e6;
    width: 2px;
}
QSplitter::handle:hover {
    background-color: #007bff;
}

/* ── 对话框 ── */
QDialog {
    background-color: #ffffff;
}
QLabel {
    background: transparent;
}

/* ── 滚动条 ── */
QScrollBar:vertical {
    border: none;
    background: #f8f9fa;
    width: 10px;
    border-radius: 5px;
}
QScrollBar::handle:vertical {
    background: #ced4da;
    min-height: 30px;
    border-radius: 5px;
}
QScrollBar::handle:vertical:hover {
    background: #adb5bd;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}
