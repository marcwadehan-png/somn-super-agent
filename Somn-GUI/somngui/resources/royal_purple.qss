/*
 * Somn GUI - Royal Purple Theme
 * 皇家紫罗兰风格，优雅高贵
 */

/* ── 全局 ── */
QMainWindow {
    background-color: #f0eaf5;
}
QWidget {
    font-family: "Microsoft YaHei", "Segoe UI", Arial, sans-serif;
    font-size: 13px;
    color: #3a2a4c;
}

/* ── 菜单栏 ── */
QMenuBar {
    background-color: #ffffff;
    border-bottom: 1px solid #c8b0e0;
    padding: 2px;
}
QMenuBar::item {
    padding: 6px 12px;
    background: transparent;
}
QMenuBar::item:selected {
    background-color: #e0d0f0;
    border-radius: 4px;
}
QMenu {
    background-color: #ffffff;
    border: 1px solid #c8b0e0;
    border-radius: 8px;
    padding: 6px;
}
QMenu::item {
    padding: 6px 24px;
    border-radius: 4px;
}
QMenu::item:selected {
    background-color: #7B1FA2;
    color: white;
}
QMenu::separator {
    height: 1px;
    background: #c8b0e0;
    margin: 4px 8px;
}

/* ── 标签页 ── */
QTabWidget::pane {
    border: 1px solid #c8b0e0;
    border-radius: 8px;
    background-color: #ffffff;
    padding: 8px;
}
QTabBar::tab {
    background-color: #e0d0f0;
    color: #6a1b9a;
    padding: 8px 20px;
    margin-right: 2px;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    font-weight: bold;
}
QTabBar::tab:selected {
    background-color: #ffffff;
    color: #7B1FA2;
    border-bottom: 2px solid #7B1FA2;
}

/* ── 按钮通用 ── */
QPushButton {
    background-color: #e0d0f0;
    border: 1px solid #c8b0e0;
    border-radius: 6px;
    padding: 6px 16px;
    color: #3a2a4c;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #c8b0e0;
    border-color: #ab80d0;
}
QPushButton:pressed {
    background-color: #ab80d0;
    color: white;
}
QPushButton:disabled {
    background-color: #f0eaf5;
    color: #c8b0e0;
}

/* ── 输入框 ── */
QLineEdit, QTextEdit {
    background-color: #ffffff;
    border: 1px solid #c8b0e0;
    border-radius: 6px;
    padding: 8px;
    selection-background-color: #7B1FA2;
    selection-color: white;
}
QLineEdit:focus, QTextEdit:focus {
    border-color: #7B1FA2;
}

/* ── 文本浏览（聊天显示区） ── */
QTextBrowser {
    background-color: #f8f2fc;
    border: 1px solid #c8b0e0;
    border-radius: 8px;
    padding: 12px;
    font-size: 13px;
}

/* ── 列表 ── */
QListWidget, QTreeWidget {
    background-color: #ffffff;
    border: 1px solid #c8b0e0;
    border-radius: 6px;
    padding: 4px;
    alternate-background-color: #f8f2fc;
}
QListWidget::item, QTreeWidget::item {
    padding: 4px 8px;
    border-radius: 4px;
}
QListWidget::item:hover, QTreeWidget::item:hover {
    background-color: #e0d0f0;
}
QListWidget::item:selected, QTreeWidget::item:selected {
    background-color: #7B1FA2;
    color: white;
}

/* ── 状态栏 ── */
QStatusBar {
    background-color: #ffffff;
    border-top: 1px solid #c8b0e0;
    color: #8a6aaa;
    font-size: 12px;
    padding: 2px 8px;
}
QProgressBar {
    border: 1px solid #c8b0e0;
    border-radius: 4px;
    text-align: center;
    background-color: #e0d0f0;
    height: 16px;
}
QProgressBar::chunk {
    background-color: #7B1FA2;
    border-radius: 3px;
}

/* ── 分隔器 ── */
QSplitter::handle {
    background-color: #c8b0e0;
    width: 2px;
}
QSplitter::handle:hover {
    background-color: #7B1FA2;
}

/* ── 对话框 ── */
QDialog {
    background-color: #ffffff;
}
QLabel {
    background: transparent;
}

/* ── 滚动条 ── */
QScrollBar:vertical {
    border: none;
    background: #f8f2fc;
    width: 10px;
    border-radius: 5px;
}
QScrollBar::handle:vertical {
    background: #c8b0e0;
    min-height: 30px;
    border-radius: 5px;
}
QScrollBar::handle:vertical:hover {
    background: #ab80d0;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}
