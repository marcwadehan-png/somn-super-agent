# Somn LLM Service 环境变量配置示例
# 复制此文件为 .env 并填入你的 API Key

# ========== 国产大模型 (推荐) ==========

# 豆包 / 火山方舟 (字节跳动)
# 申请地址: https://www.volcengine.com/product/ark
# VOLCENGINE_API_KEY=your-volcengine-api-key
# DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/v1
# DOUBAO_MODEL=doubao-pro-32k

# DeepSeek (深度求索)
# 申请地址: https://platform.deepseek.com/
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# 腾讯混元 / 元宝
# 申请地址: https://cloud.tencent.com/product/hunyuan
# HUNYUAN_API_KEY=your-hunyuan-api-key
# HUNYUAN_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
# HUNYUAN_MODEL=hunyuan-turbos-latest

# 通义千问 (阿里云)
# 申请地址: https://dashscope.console.aliyun.com/
# DASHSCOPE_API_KEY=your-dashscope-api-key
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-max

# ========== 其他模型 ==========

# OpenAI
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4

# ========== 本地模型 (Ollama) ==========
# SOMN_LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
# SOMN_LOCAL_LLM_MODEL=qwen2.5:7b-instruct
# SOMN_LOCAL_LLM_TIMEOUT=120

# ========== 默认模型选择 ==========
# 可选: doubao, deepseek, hunyuan, qwen, local-default, gpt-4 等
# SOMN_DEFAULT_MODEL=doubao
