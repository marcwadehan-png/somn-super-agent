"""
解决方案智能学习引擎
Solution Learning Engine - 持续学习行业TOP服务商能力,不断迭代完善解决方案
"""
from enum import Enum
from dataclasses import dataclass, asdict, field
from pathlib import Path
from typing import Dict, List, Optional, Any
import json, yaml, hashlib
from datetime import datetime
import warnings


def safe_yaml_load(file_path: Path) -> Optional[Dict[str, Any]]:
    """
    安全加载YAML文件,兼容新旧格式
    - 新格式:纯YAML(无Python对象标记)
    - 旧格式:包含!!python/object标记的文件
    
    注意:对于旧格式文件中的Python对象,只提取其值而非对象本身
    """
    try:
        with open(file_path, 'r', encoding='utf-8') as f:
            content = f.read()
        
        # 检查是否有Python对象标记
        if '!!python/object' in content:
            # 旧格式文件:使用UnsafeLoader加载,它能处理Python对象
            # 但我们将提取对象的核心数据(.value 或 .__dict__)
            try:
                data = yaml.load(content, Loader=yaml.UnsafeLoader)
                # 如果加载成功,尝试提取有用的数据
                return _extract_python_object_data(data)
            except Exception:
                # 如果UnsafeLoader也失败,使用纯文本提取
                return _extract_basic_fields(content)
        else:
            # 新格式文件,安全加载
            return yaml.safe_load(content)
            
    except Exception as e:
        # 加载失败,返回None
        warnings.warn(f"加载YAML文件失败 {file_path}: {e}")
        return None


def _extract_python_object_data(obj: Any) -> Dict[str, Any]:
    """
    从Python对象中提取核心数据
    用于处理旧格式中序列化 dataclass/Enum 的情况
    """
    if obj is None:
        return {}
    
    # 如果是字典,递归处理每个值
    if isinstance(obj, dict):
        result = {}
        for k, v in obj.items():
            extracted = _extract_python_object_data(v)
            if extracted is not None:
                result[k] = extracted
        return result
    
    # 如果是列表,递归处理每个元素
    if isinstance(obj, list):
        return [_extract_python_object_data(item) for item in obj]
    
    # 如果是Enum,提取其值
    if isinstance(obj, Enum):
        return obj.value
    
    # 如果是普通对象(有__dict__),递归处理
    if hasattr(obj, '__dict__'):
        return _extract_python_object_data(obj.__dict__)
    
    # 其他情况直接返回
    return obj


def _extract_basic_fields(content: str) -> Dict[str, Any]:
    """
    从包含Python对象标记的旧格式YAML中提取基本字段
    这是一个降级方案,用于尽可能恢复数据
    """
    result = {}
    
    # 简单的字段提取(适用于LearningSession)
    simple_fields = [
        'session_id', 'provider_name', 'category', 'status', 
        'source_type', 'capabilities_count', 'started_at', 'completed_at'
    ]
    
    for field_name in simple_fields:
        # 匹配 field_name: value 格式
        import re
        pattern = rf'^{field_name}:\s*(.+?)$'
        match = re.search(pattern, content, re.MULTILINE)
        if match:
            value = match.group(1).strip()
            # 移除引号
            if value.startswith('"') and value.endswith('"'):
                value = value[1:-1]
            elif value.startswith("'") and value.endswith("'"):
                value = value[1:-1]
            result[field_name] = value
    
    return result


def safe_yaml_dump(data: Any, file_path: Path) -> bool:
    """
    安全保存YAML文件(始终使用纯YAML格式,不含Python对象)
    """
    try:
        with open(file_path, 'w', encoding='utf-8') as f:
            yaml.dump(data, f, allow_unicode=True, default_flow_style=False, 
                     sort_keys=False)
        return True
    except Exception as e:
        warnings.warn(f"保存YAML文件失败 {file_path}: {e}")
        return False


class LearningSourceType(Enum):
    SERVICE_PROVIDER = "service_provider"
    CASE_STUDY = "case_study"
    USER_FEEDBACK = "user_feedback"
    MARKET_RESEARCH = "market_research"


class CapabilityType(Enum):
    CORE_FEATURE = "核心功能"
    SELLING_POINT = "核心卖点"
    TECHNOLOGY = "技术能力"
    SERVICE = "服务能力"
    IMPLEMENTATION = "落地能力"
    INDUSTRY_EXPERTISE = "行业专业度"


@dataclass
class ServiceProvider:
    provider_id: str
    name: str
    category: str
    website: str = ""
    description: str = ""
    capabilities: Dict[str, List[str]] = field(default_factory=dict)
    created_at: str = ""
    updated_at: str = ""


@dataclass
class CapabilityInsight:
    insight_id: str
    capability_type: str
    content: str
    source_provider: str
    frequency: int = 1
    confidence: float = 0.8
    applications: List[str] = field(default_factory=list)


@dataclass
class LearningSession:
    session_id: str
    provider_name: str
    category: str
    status: str
    source_type: str = "service_provider"
    capabilities_count: int = 0
    new_capabilities: List[object] = field(default_factory=list)
    started_at: str = ""
    completed_at: str = ""


# ====== 辅助函数(模块级)======
def _enum_to_str(obj):
    """递归将Enum值转为字符串,用于YAML序列化"""
    if isinstance(obj, Enum):
        return obj.value
    elif isinstance(obj, dict):
        return {k: _enum_to_str(v) for k, v in obj.items()}
    elif isinstance(obj, list):
        return [_enum_to_str(item) for item in obj]
    return obj


class SolutionLearningEngine:
    """
    解决方案智能学习引擎

    核心能力:
    1. 服务商信息收集与学习
    2. 能力characteristics提取与聚类
    3. 解决方案模板迭代更新
    4. 持续学习积累专业知识
    """

    def __init__(self, base_path: str = "data/solution_learning"):
        self.base_path = Path(base_path)

        # 数据目录
        self.providers_path = self.base_path / "providers"
        self.insights_path = self.base_path / "insights"
        self.sessions_path = self.base_path / "sessions"
        self.patterns_path = self.base_path / "patterns"
        self.daily_logs_path = self.base_path / "daily_logs"

        # 创建目录
        for path in [self.providers_path, self.insights_path, self.sessions_path,
                     self.patterns_path, self.daily_logs_path]:
            path.mkdir(parents=True, exist_ok=True)

        # 学习配置
        self.config = {
            "top_providers_per_category": 20,
            "min_confidence": 0.75,
            "similarity_threshold": 0.85,
            "max_insights_per_session": 20,
        }

        # init服务商数据库
        self.provider_database = self._init_provider_database()

