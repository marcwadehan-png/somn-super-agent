        # 从真实研究库中get内容
        if category in REAL_RESEARCH:
            cat_data = REAL_RESEARCH[category]
            for cap_type, items in cat_data.items():
                for item in items:
                    # 解析格式: "名称 - 描述"
                    if " - " in item:
                        name_part, desc_part = item.split(" - ", 1)
                        capabilities[cap_type].append({
                            "name": name_part.strip(),
                            "description": desc_part.strip(),
                            "provider": "行业研究"
                        })
                    else:
                        capabilities[cap_type].append({
                            "name": item,
                            "description": "",
                            "provider": "行业研究"
                        })

        # 从文本内容中补充提取
        for cap_type in CapabilityType:
            cap_key = cap_type.value
            patterns = {
                "核心功能": ["自动化", "管理", "分析", "追踪", "监控"],
                "核心卖点": ["领先", "首创", "独家", "专业", "专注"],
                "技术能力": ["架构", "API", "集成", "加密", "部署"],
                "服务能力": ["培训", "支持", "咨询", "服务", "维护"],
                "落地能力": ["实施", "交付", "上线", "集成", "配置"],
            }
            if cap_key in patterns:
                for keyword in patterns[cap_key]:
                    if keyword in content and len(capabilities[cap_key]) < 15:
                        capabilities[cap_key].append({
                            "name": f"{keyword}相关能力",
                            "description": f"基于{keyword}的服务能力",
                            "provider": "文本提取"
                        })

        return {"capabilities": capabilities, "source": content}

    def _generate_insights(
        self, extracted: Dict, provider_name: str, category: str
    ) -> List[CapabilityInsight]:
        """generate能力洞察"""
        insights = []

        for capability_type, capabilities in extracted.get("capabilities", {}).items():
            for cap in capabilities:
                cap_name = cap.get("name", "").strip()
                if not cap_name or len(cap_name) < 2:
                    continue

                insight_id = hashlib.md5(
                    f"{category}_{capability_type}_{cap_name}".encode()
                ).hexdigest()[:16]

                # 构造描述
                description = cap.get("description", "")
                if description:
                    content = f"{provider_name}提供{capability_type}"{cap_name}":{description}"
                else:
                    content = f"{provider_name}提供{capability_type}"{cap_name}""

                # 置信度:文本提取0.75,行业研究0.82
                confidence = 0.82 if cap.get("provider") == "行业研究" else 0.75

                # 推荐应用场景
                scenario = self._suggest_scenario(cap_name, category)

                insight = CapabilityInsight(
                    insight_id=insight_id,
                    capability_type=capability_type,
                    content=content,
                    source_provider=provider_name,
                    frequency=1,
                    confidence=confidence,
                    applications=[scenario] if scenario else []
                )
                insights.append(insight)

        return insights

