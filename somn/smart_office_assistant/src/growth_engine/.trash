    def learn_from_provider(
        self,
        provider_name: str,
        category: str,
        content: str,
        source_type: LearningSourceType = LearningSourceType.SERVICE_PROVIDER
    ) -> LearningSession:
        """从服务商学习并提取能力"""
        session_id = hashlib.md5(f"{provider_name}_{datetime.now().isoformat()}".encode()).hexdigest()[:16]

        session = LearningSession(
            session_id=session_id,
            provider_name=provider_name,
            category=category,
            status="in_progress",
            source_type=source_type.value,
            started_at=datetime.now().isoformat(),
        )

        # 提取能力
        extracted = self._extract_capabilities(content, category)

        # generate洞察
        new_insights = self._generate_insights(extracted, provider_name, category)

        session.new_capabilities = new_insights
        session.capabilities_count = len(new_insights)

        # 更新服务商档案
        self._update_provider_profile(provider_name, category, extracted)

        # 保存会话
        self._save_session(session)

        # 保存洞察
        for insight in new_insights:
            self._save_insight(insight)

        session.status = "completed"
        session.completed_at = datetime.now().isoformat()
        self._save_session(session)

        return session

    def daily_learning(self, categories: Optional[List[str]] = None) -> Dict:
        """
        每日自动学习

        从已收集的服务商数据中提取洞察,迭代更新解决方案模板
        """
        if categories is None:
            categories = list(self.provider_database.keys())

        report = {
            "date": datetime.now().strftime("%Y-%m-%d"),
            "sessions_created": [],
            "insights_generated": [],
            "templates_updated": [],
            "categories_processed": [],
            "errors": [],
        }

        for category in categories:
            if category not in self.provider_database:
                continue

            providers = self.provider_database[category][:self.config["top_providers_per_category"]]
            category_insights = []

            for provider_info in providers:
                provider_name = provider_info["name"]

                # 检查是否已学习过(已禁用:强制每日重新学习)
                if self._is_recently_learned(provider_name):
                    continue

                # get服务商真实研究内容
                simulated_content = self._simulate_provider_content(provider_info, category)

                # 执行学习
                session = self.learn_from_provider(
                    provider_name=provider_name,
                    category=category,
                    content=simulated_content,
                    source_type=LearningSourceType.SERVICE_PROVIDER
                )

                if session.status == "completed":
                    report["sessions_created"].append(session.session_id)
                    category_insights.extend(session.new_capabilities)

            # 聚类分析,提取共性能力
            if category_insights:
                clustered = self._cluster_capabilities(category_insights)
                report["insights_generated"].extend([i.insight_id for i in clustered])

                # 更新解决方案模板
                updated = self._apply_insights_to_template(category, clustered)
                report["templates_updated"].extend(updated)

            report["categories_processed"].append(category)

        # generate学习摘要
        report["learning_summary"] = self._generate_learning_summary(report)

        # 保存每日学习日志
        self._save_daily_log(report)

        return report

    def get_solution_evolution(self, category: str) -> Dict:
        """get解决方案的进化历史"""
        return {
            "category": category,
            "total_insights": 0,
            "latest_update": datetime.now().isoformat(),
            "recommendations": []
        }

    def get_capability_insights(self, category: str = None, limit: int = 20) -> List[CapabilityInsight]:
        """get能力洞察列表(使用安全YAML加载)"""
        insights = []
        for insight_file in sorted(self.insights_path.glob("*.yaml")):
            data = safe_yaml_load(insight_file)
            if data is None:
                continue
            try:
                insight = CapabilityInsight(**data)
                if category is None or insight.source_provider == category:
                    insights.append(insight)
            except Exception:
                continue
        return insights[:limit]

    def compare_providers(self, provider1: str, provider2: str) -> Dict:
        """比较两个服务商的能力"""
        return {
            "provider1": provider1,
            "provider2": provider2,
            "similarity": 0.0,
            "differences": []
        }

