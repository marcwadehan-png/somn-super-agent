# Somn项目 - Flake8 风格检查配置
# 继承自 pyproject.toml [tool.flake8]，此文件用于IDE集成

[flake8]
max-line-length = 120
max-doc-length = 100
exclude =
    .git,
    __pycache__,
    .pytest_cache,
    data,
    node_modules,
    tests,
    smart_office_assistant/data,
    smart_office_assistant/.git,
    smart_office_assistant/node_modules

ignore =
    E203,  # whitespace before ':'
    E501,  # line too long (pylint控制)
    W503   # line break before binary operator

per-file-ignores =
    __init__.py:F401,F403

count = True
statistics = True
show-source = True

# 复杂度相关
max-complexity = 15
